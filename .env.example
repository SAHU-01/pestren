# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and paste your real URI there.
# `.env.local` is gitignored — it will NOT be committed.
#
#   cp .env.example .env.local
#
# Then paste the connection string from Atlas → Connect → Drivers,
# with <password> replaced by your real DB user password.
# ─────────────────────────────────────────────────────────────

MONGODB_URI="mongodb+srv://pestren_writer:<password>@pestren-cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority"
